{
  "expo": {
    "name": "fitmate-ai",
    "slug": "fitmate-ai",
    "scheme": "fitmate-ai",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/app-logo.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "운동 자세 분석을 위해 카메라 접근 권한이 필요합니다.",
          "enableCodeScanner": false
        }
      ],
      "expo-router",
      "expo-web-browser"
    ],
    "orientation": "portrait",
    "icon": "./assets/app-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
